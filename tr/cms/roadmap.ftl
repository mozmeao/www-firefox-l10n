### The Roadmap page shows a list of features coming up on Firefox

# Label indicating when the list was last updated
# Variables:
#    $date (string) Date when the page was last updated
roadmap-last-updated = Son güncelleme: { $date }

## Pill indicating the status of an item in Firefox's roadmap

roadmap-status-exploring = Keşfediliyor
roadmap-status-in-progress = Devam ediyor
roadmap-status-testing = Test ediliyor
roadmap-status-coming-soon = Çok yakında

## Tag indicating where the feature is available

roadmap-tag-desktop = Masaüstü
roadmap-tag-android = { -brand-name-android }
roadmap-tag-ios = { -brand-name-ios }
