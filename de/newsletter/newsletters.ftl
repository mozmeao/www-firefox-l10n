### URL: https://www-dev.springfield.moz.works/newsletter/

# Headline for /newsletter/
newsletters-make-the-most = Mach das Beste aus { -brand-name-firefox }

# Subtitle for /newsletter/
newsletters-sign-up-to-receive-monthly = Melde dich für monatliche Updates von { -brand-name-firefox } und den neuesten Internet-Trends an und gestalte dein Online-Leben.

# Enterprise
newsletter-enterprise-title-v2 = Abonniere die Enterprise Updates für { -brand-name-mozilla }

newsletter-enterprise-description-v3 = Bleibe über { -brand-name-firefox-enterprise }, { -brand-name-firefox-professional-support } sowie relevante Webinare, Events und Produkt-Updates für IT, Sicherheit und Compliance-Mitarbeitende auf dem Laufenden.
newsletter-enterprise-description-note = Hinweis: Dein Abonnement ist freiwillig und kann jederzeit gekündigt werden.

# Consent checkbox label in the enterprise newsletter form
newsletter-enterprise-form-consent-v3 = Mit dem Abschicken dieses Formulars stimmst du zu, dass { -brand-name-mozilla } dich mit Enterprise-Produkten, Events, Produkt-Updates und zugehörigen Themen zu IT, Sicherheit und Compliance kontaktiert.

newsletter-enterprise-form-consent-details-v3 = Diese E-Mails können Informationen über { -brand-name-firefox-enterprise }, { -brand-name-firefox-professional-support }, Webinare, Events und Produkt-Updates beinhalten und Updates für IT, Sicherheit und Compliance-Themen in den Blickpunkt stellen. Ich kann meine Zustimmung mit Wirkung für die Zukunft jederzeit widerrufen.

# Privacy notice section below the enterprise newsletter form
newsletter-enterprise-privacy-statement = { -brand-name-mozilla } wird die von dir bereitgestellten Informationen nutzen, um die ausgewählte E-Mail-Kommunikationen zuzuschicken und deine Zustimmung zu dokumentieren. Weitere Informationen findest du im Datenschutzhinweis von { -brand-name-mozilla }.
newsletter-enterprise-privacy-link = Datenschutzhinweis
newsletter-enterprise-legal-link = Rechtliche Hinweise
