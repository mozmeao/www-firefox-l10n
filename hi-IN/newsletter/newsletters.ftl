### URL: https://www-dev.springfield.moz.works/newsletter/

# Headline for /newsletter/
newsletters-make-the-most = { -brand-name-firefox } का अधिकतम लाभ उठाएं

# Subtitle for /newsletter/
newsletters-sign-up-to-receive-monthly = { -brand-name-firefox } से ऐसे मासिक अपडेट और इंटरनेट ट्रेंड पाने के लिए साइन अप करें जो आपके ऑनलाइन जीवन पर असर डालते हैं।

# Enterprise
newsletter-enterprise-title-v2 = { -brand-name-mozilla } Enterprise अपडेट्स के लिए सब्सक्राइब करें

newsletter-enterprise-description-v3 = { -brand-name-firefox-enterprise }, { -brand-name-firefox-professional-support } के बारे में जानकारी पाते रहें, साथ ही आईटी, सुरक्षा और कंप्लायंस प्रोफ़ेशनल्स के लिए प्रासंगिक वेबिनार, इवेंट्स और प्रोडक्ट अपडेट्स की खबर रखें।
newsletter-enterprise-description-note = ध्यान दें: आपका सब्सक्रिप्शन आपकी मर्ज़ी पर निर्भर है और आप इसे कभी भी बंद कर सकते हैं।

# Consent checkbox label in the enterprise newsletter form
newsletter-enterprise-form-consent-v3 = यह फ़ॉर्म सबमिट करके, आप { -brand-name-mozilla } को Enterprise प्रोडक्ट, इवेंट, प्रोडक्ट अपडेट और साथ ही साथ प्रासंगिक आईटी, सुरक्षा व कंप्लायंस विषयों के बारे में आपसे संपर्क करने की सहमति देते हैं।

newsletter-enterprise-form-consent-details-v3 = इन ईमेल में { -brand-name-firefox-enterprise }, { -brand-name-firefox-professional-support }, वेबिनार, इवेंट, प्रोडक्ट अपडेट के बारे में जानकारी और आईटी, सुरक्षा व कंप्लायंस विषयों संबंधी फ़ीचर अपडेट हो सकते हैं। मेरा पास यह विकल्प है कि मैं किसी भी समय भविष्य के लिए अपनी सहमति वापस ले लूं।

# Privacy notice section below the enterprise newsletter form
newsletter-enterprise-privacy-statement = { -brand-name-mozilla } आपके द्वारा दी गई जानकारी का इस्तेमाल आपको चुनिंदा ईमेल मैसेज भेजने और आपकी सहमति का रिकॉर्ड रखने के लिए करेगा। ज़्यादा जानकारी के लिए, { -brand-name-mozilla } के प्राइवेसी नोटिस (गोपनीयता सूचना) को देखें।
newsletter-enterprise-privacy-link = निजता सूचना
newsletter-enterprise-legal-link = कानूनी नोटिस
